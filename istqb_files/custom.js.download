function registerResetFilter()
{
    $('#resetFilter').click(function(e) {
        var table = $('.dataTable').DataTable();
        table.state.clear();
        table.search('').columns().search('').draw();
        if (table.table().node().id === 'datagridExam') {
            $('#form-filter input[type="text"], #form-filter textarea').val('');
            $('#form-filter input[type="checkbox"], #form-filter input[type="radio"]').prop('checked', false);
            $('#form-filter select').prop('selectedIndex', 0);
        }
        if (table.table().node().id === 'datagridExamineeProfile') {
            $('#form-filter input[type="text"], #form-filter textarea').val('');
            $('#form-filter input[type="checkbox"], #form-filter input[type="radio"]').prop('checked', false);
            $('#form-filter select').prop('selectedIndex', 0);
        }
        table.state.save();
    });
}

