function registerShowHistory()
{
    jQuery('#btnShowHistory').on('click', function(){
        var progressBar = jQuery('.modal-body #tempprogressbar');
        progressBar.fadeIn();
        jQuery('.modal-body .content').html('');
        var url = jQuery(this).data('id');
        $.get(url, function(data){
            var out = 'An error is occured.';
            if(data){
                out = data;
            }
            progressBar.fadeOut();
            jQuery('.modal-body .content').html(data);
        });
    })
}

function registerShowProfileAddresses()
{
    var item = $('#form-examParticipation #fieldset-displayGroupAddress');
    var url = item.attr('data-source');
    url = url + '/format/html';
    $.get(url, function(data){
        var out = 'An error is occured.';
        if(data){
            out = data;
        }
        $('legend', item).after(out);
        $('.assignAddress').on('click', function(){
            alert('showprofile');
            var btn = $(this);
            var tr = btn.parents('tr');
            $('#addressLine1').val($('.addressLine1', tr).text());
            $('#addressLine2').val($('.addressLine2', tr).text());
            $('#addressLine3').val($('.addressLine3', tr).text());
            $('#postOfficeBox').val($('.postOfficeBox', tr).text());
            $('#postalCode').val($('.postalCode', tr).text());
            $('#city').val($('.city', tr).text());
            $('#country option').filter(function(){
                return $(this).text() == $('.country', tr).text();
            }).attr('selected', true);
        })
    });
}

function registerAssignAddress()
{
    $(document).on('click', '.assignAddress', function(){
        var btn = $(this);
        var prefix = btn.data('prefix');
        var tr = btn.parents('tr');
        var address = {
            company: $('td:eq(0)', tr).text(),
            emailAddress: $('td:eq(1)', tr).text(),
            addressLine1: $('td:eq(2)', tr).text(),
            addressLine2: $('td:eq(3)', tr).text(),
            addressLine3: $('td:eq(4)', tr).text(),
            postOfficeBox: $('td:eq(5)', tr).text(),
            postalCode: $('td:eq(6)', tr).text(),
            city: $('td:eq(7)', tr).text(),
            country: $('td:eq(8)', tr).text()
        };
        putAddressValues(address, prefix);
    })
}

function putAddressValues(address, prefix)
{
    if (address.emailAddress == '-') {
        address.emailAddress = '';
    }
    $('#' + prefix + 'company').val(address.company);
    $('#' + prefix + 'emailAddress').val(address.emailAddress);
    $('#' + prefix + 'addressLine1').val(address.addressLine1);
    $('#' + prefix + 'addressLine2').val(address.addressLine2);
    $('#' + prefix + 'addressLine3').val(address.addressLine3);
    $('#' + prefix + 'postOfficeBox').val(address.postOfficeBox);
    $('#' + prefix + 'postalCode').val(address.postalCode);
    $('#' + prefix + 'city').val(address.city);
    $('#' + prefix + 'country option').filter(function(){
        return $(this).text() == address.country;
    }).attr('selected', true);
}

function prefillPriceValues() {

    $('#prefillPriceServices').on('click', function(e) {

        var div = $('#priceServicesMessage');
        var url = $('#prefillPriceServices').data('href');
        $.get(url, function(data){
            if(data){
                div.html(data.message);
                if(data.success) {
                    $('#priceServices').val(data.price);
                }
            }
        });
    });

    $('#prefillPrice').on('click', function(e) {
        var entityId = $('#entityId').val();
        var tp = $('#trainingProviderProfile').val();
        var em = $('#examMethod').val();
        var es = $('#examSet').val();
        var examDurationExtension = $('#examDurationExtension').val();
        var resit = Number($('#resit').is(':checked'));
        var otherResit = Number($('#otherResit').is(':checked'));
        var personnel = Number($('#personnel').is(':checked'));
        var student = Number($('#student').is(':checked'));
        var asqfMember = Number($('#asqfMember').is(':checked'));
        var examDurationExtensionProof = Number($('#examDurationExtensionProof').is(':checked'));
        var timeExtension = examDurationExtension || examDurationExtensionProof ? 1 : 0;
        var div = $('#priceMessage');
        var url = $('#prefillPrice').data('href');
        url += '/profile/' + tp + '/examMethod/' + em + '/examSet/' + es + '/resit/' + resit + '/otherResit/' + otherResit + '/personnel/' + personnel;
        url += '/student/' + student + '/asqfMember/' + asqfMember + '/timeExtension/' + timeExtension;
        $.get(url, function(data){
            if(data){
                div.html(data.message);
                if(data.success) {
                    $('#currency').val(data.currency);
                    $('#price').val(data.price);
                    $('#licencefee').val(data.licencefee);
                }
            }
        });
    });
}

/* Customizing Bootstrap Popover */
$.fn.popover.defaults = $.extend({} , $.fn.tooltip.defaults, {
    placement: 'left',
    trigger: 'focus',
    content: '',
    template: '<div style="width: auto;" class="popover alert-danger has-error"><div class="arrow"></div><div class="popover-inner"><div class="popover-content"><p></p></div></div></div>'
});

/* Customizing SearchFilter */
$.extend($.fn.dataTableExt.oStdClasses, {
    "sWrapper": "dataTables_wrapper form-inline dt-bootstrap",
    "sFilterInput": "form-control input-sm",
    "sLengthSelect": "form-control input-sm"
});

$.fn.dataTableExt.oApi.fnPagingInfo = function ( oSettings )
{
    return {
        "iStart":         oSettings._iDisplayStart,
        "iEnd":           oSettings.fnDisplayEnd(),
        "iLength":        oSettings._iDisplayLength,
        "iTotal":         oSettings.fnRecordsTotal(),
        "iFilteredTotal": oSettings.fnRecordsDisplay(),
        "iPage":          Math.ceil( oSettings._iDisplayStart / oSettings._iDisplayLength ),
        "iTotalPages":    Math.ceil( oSettings.fnRecordsDisplay() / oSettings._iDisplayLength )
    };
}
