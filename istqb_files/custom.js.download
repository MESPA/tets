function registerToggleBulkMail(selector, href)
{
    $('#isMailChecked').on('click', function(){
        var add = '/mail/1';
        if($('input[id=isMailChecked]:checked').val()){
            $(selector).attr('href', href + add);
        } else {
            $(selector).attr('href', href);
        }
    })
}

function toggleBillingAddress(trigger, domTarget) {

    _toggleBillingAddress(trigger, domTarget);
    trigger.click(function(){
        _toggleBillingAddress($(this), domTarget);
    })
}

function _toggleBillingAddress(trigger, domTarget) {

    if (trigger.attr('checked')) {
        domTarget.fadeIn();
        $('[name^="billing_"]').each(function(){
            $(this).removeAttr('readonly');
        })
    } else {
        domTarget.fadeOut();
        $('[name^="billing_"]').each(function(){
            $(this).popover('hide')
            $(this).attr('readonly', 'readonly');
        })
    }
}

function toggleProof() {
    $('.fadeInOut').fadeOut();
    $('.fadeInOut2').fadeOut();
    $('#furtherProof').click(
        function(){
            $('#furtherProof').fadeOut();
            $('.fadeInOut').fadeIn();
        })
    $('#furtherProof2').click(
        function(){
            $('#furtherProof2').fadeOut();
            $('.fadeInOut2').fadeIn();
        })
}

function toggleChangePassword(triggerCheckbox) {
    var domElement = $('.passwordrow');
    if (triggerCheckbox.prop('checked')) {
        domElement.fadeIn();
    } else {
        domElement.fadeOut();
    }
}

function toggleRow() {
    $('#region').change(
        function(){
            var val = $('#region').val();
            $('#examset-prices table tr').each(function() {
                if (val == '' || $(this).find('.region-' + val).length > 0) {
                    $(this).fadeIn();
                } else {
                    $(this).fadeOut();
                }
            })
        })
}

function toggleGotoProfile(triggerElement, buttonElement, isFirst)
{
    triggerElement.popover('destroy');

    if (isFirst) {
        triggerElement.change(function() {
            toggleGotoProfile(triggerElement, buttonElement, false);
        });

        buttonElement.on('click', function() {
            window.open($(this).attr('data-href'), '_blank');
        });
    }

    var domElement = buttonElement.parents('div.form-group');
    var hrefEdit = buttonElement.attr('data-href-edit');
    var id = triggerElement.val();
    if (id > 0 && hrefEdit) {
        buttonElement.attr('data-href', hrefEdit + '/id/' + id);

        if (! isFirst) {
            buttonElement.append('<span class="glyphicon glyphicon-refresh glyphicon-spin" style="margin-left: 15px;"></span>');
            $.ajax({
                url: buttonElement.attr('data-href-show') + '/id/' + id
            }).done(function(data) {
                if (data.comment) {
                    triggerElement.popover({
                        html: true,
                        title: 'Special conditions <button type="button" class="close">&times;</button>',
                        content: data.comment,
                        placement: 'top'
                    }).on('shown.bs.popover', function() {
                        var popover = $(this);
                        $(this).parent().find('div.popover .close').on('click', function() {
                            popover.popover('hide');
                        });
                    }).popover('show');
                }
                buttonElement.find('span').remove();
            });
        }

        domElement.fadeIn();
    } else {
        domElement.fadeOut();
    }
}

function toggleProductFields(trigger, domTarget)
{
    var service = 'Service';
    function toggle(trigger, boardsValue) {
        var fadingFields = ['previousTraining', 'examScheme', 'examLevel', 'durationExtension'];
        if (trigger.val() == boardsValue) {
            $.each(fadingFields, function (index, value) {
                $('#' + value).parent().parent().fadeOut();
            });
        } else {
            $.each(fadingFields, function (index, value) {
                $('#' + value).parent().parent().fadeIn();
            });
        }
    }
    toggle(trigger, service);
    $(trigger).change(function () {
        toggle(trigger, service);
    })
}

