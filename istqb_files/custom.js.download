$(document).ajaxError(function(event, jqxhr, settings, exception) {
    if (jqxhr.status === 401) {
        alert('Your session has expired. Please login.');
        location.reload();
    }
});

$(document).ready(function() {
    /* Initialize Markdown */
    $('textarea.markdown').each(function(index, element) {
        var id = $(element).attr('id');
        new SimpleMDE({ element: document.getElementById(id) });
    });

    /* Initialize Datepicker */
    $('.datepicker').each(function() {
        $(this).datetimepicker({
            locale: ZertDB.locale,
            format: 'L',
            extraFormats: ['DD MMM YYYY'],
            useCurrent: false,
            toolbarPlacement: 'bottom',
            showTodayButton: true,
            showClear: true,
            showClose: true

        })
    });

    $('.datetimepicker').each(function() {
        $(this).datetimepicker({
            locale: ZertDB.locale,
            format: 'L LT',
            extraFormats: ['DD MMM YYYY hh:mm:ss'],
            useCurrent: false,
            toolbarPlacement: 'bottom',
            showTodayButton: true,
            showClear: true,
            showClose: true,
            sideBySide: true
        });
    });

    $('#datagridVmod').each(function() {
        var table = $(this);
        var options = {
            "bServerSide": false,
