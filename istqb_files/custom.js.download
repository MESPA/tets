        event.preventDefault();
    })
}

function registerButtonRemoveSection()
{
    $('.buttonRemoveSection').each(function(event){
        event.preventDefault();
    })
}

function registerExportButton()
{
    $('#export').click(function(e) {
        e.preventDefault();
        var url = $(this).attr('href');

        // Greife auf die erste DataTable auf der Seite zu
        var table = $('.dataTable').first().DataTable(); // Nutzt die erste Tabelle mit DataTable-Integration
        var order = table.order(); // Hole die aktuelle Sortierung

        // Baue die Sortierparameter als Query-String
        var orderParams = order.map(function(o) {
            return 'order[' + o[0] + ']=' + o[1];
        }).join('&');

        // Kombiniere Filterdaten und Sortierdaten
        var queryString = $('.form-filter').serialize();
        if (orderParams) {
            queryString += (queryString ? '&' : '') + orderParams;
        }

        // Navigiere zur URL mit allen Parametern
        window.location.href = url + '?' + queryString;
    });
    // $('#export').click(function(e) {
    //     e.preventDefault();
    //     var url = $(this).attr('href');
    //     window.location.href = url + '?' + $('.form-filter').serialize();
    // });
}

/**
 * Default-Settings for ajax-tables.
 * @return {Object}
 */
function getDefaultOptions()
{
    return {
        "language": {
            "url": '/vendor/datatables-i18n/i18n/' + ZertDB.locale.substring(0, 2) + '.json'
        },
        "searchDelay": 400,
        "sDom": "<'row'<'col-sm-6'l><'col-sm-6'f>r>t<'row'<'col-sm-6'i><'col-sm-6'p>>",
        "renderer": 'bootstrap',
        "bProcessing": true,
        "bServerSide": true,
        "bStateSave" : true,
        "iDisplayLength": 25,
        "aoColumnDefs": [
            { "bSortable": false, "aTargets": [ -1 ] },
            { "bSearchable": false, "aTargets": [ -1 ] }
        ],
        "fnInitComplete": function() {
            registerGeneral();
            registerConfirm();
            registerConfirmModal();
            registerAttended();
            registerAlumniconfirm();
            registerConfirmParticipation();
        },
        "fnDrawCallback": function() {
            registerConfirm();
            registerConfirmModal();
            registerAttended();
            registerAlumniconfirm();
            registerConfirmParticipation();
        },
        "fnServerData": function ( sUrl, aoData, fnCallback, oSettings ) {
            oSettings.jqXHR = $.ajax( {
                "url":  sUrl,
                "data": aoData,
                "success": function (json) {
                    if ( json.sError ) {
                        oSettings.oApi._fnLog( oSettings, 0, json.sError );
                    }

                    $(oSettings.oInstance).trigger('xhr', [oSettings, json]);
                    fnCallback( json );
                },
                "dataType": "json",
                "cache": false,
                "type": oSettings.sServerMethod,
                "error": function (xhr, error, thrown) {
                    if ( error == "parsererror" ) {
                        alert("An error occured. Please contact the support.");
                    }
                }
            });
        }
    };
}

function createDatatable(selector, options)
{
    var filterForm = $('.form-filter');
    var customFilters = jQuery(':input', filterForm);
    var filterFormParams = null;
    jQuery.fn.dataTableExt.afnFiltering = new Array();
    customFilters.each(function(){
        jQuery.fn.dataTableExt.afnFiltering.push(function( oSettings, aData, iDataIndex ) {
            if (! element.val() || element.attr('type') === 'hidden' || (element.attr('type') === 'checkbox' && element.prop('checked', true)))
                return true;
            for (i = 0; i < aData.length; i++)
                if ( aData[i].indexOf(element.val()) !== -1 )
                    return true;
            return false;
        });
    });

    selector.find('thead > tr > th').each(function(index) {
        var className = $(this).attr('class');
        if (className !== undefined) {
            if (! options.aoColumnDefs) {
                options.aoColumnDefs = [];
            }
            options.aoColumnDefs.push({ className: className, "targets": [ index ] });
            if ($(this).hasClass('actions')) {
                options.aoColumnDefs.push({ width: "1px", "targets": [ index ] });
            }
        }
    });

    var specials = {
        "fnServerParams": function ( aoData ) {
            if (filterFormParams != null) {
                aoData.push(filterFormParams);
            }
        },
        "fnDrawCallback": function( oSettings ) {
            registerConfirm();
        },
        "fnStateSaveParams": function ( oSettings, sValue ) {
            customFilters.each(function() {
                var oControl = jQuery(this);
                if (oControl.attr('name') && oControl.attr('type') !== 'hidden') {
                    if (oControl.attr('type') !== 'checkbox') {
                        sValue[oControl.attr('name')] = oControl.val().replace('"', '"');
                    } else {
                        if (oControl.is(':checked')) {
                            sValue[oControl.attr('name')] = oControl.val().replace('"', '"');
                        }
                    }
                }
            });
            return sValue;
        },
        "fnStateLoadParams": function ( oSettings, oData ) {
            customFilters.each(function() {
                var oControl = jQuery(this);
                var name = oControl.attr('name');
                jQuery.each(oData, function(key, value) {
                    if (key === name && value) {
                        if (oControl.attr('type') !== 'checkbox' && jQuery(':checkbox[name="' + name + '"]', filterForm).length === 0) {
                            oControl.val(value);
                        } else {
                            oControl.prop('checked', true);
                        }
                    }
                });
                filterFormParams = {'name': 'filterForm', 'value': filterForm.serialize()};
            });
            return true;
        },
        stateSaveCallback: function (oSettings, oData ) {

            for (var key in localStorage) {
                if (localStorage.hasOwnProperty(key) && !key.startsWith('datagrid')) {
                    localStorage.removeItem(key);
                }
            }
            var tableName = oSettings.sTableId;
            localStorage.setItem(tableName, JSON.stringify(oData));
            return true;
        },
        stateLoadCallback: function (oSettings) {
            var tableName = oSettings.sTableId;
            var savedState = localStorage.getItem(tableName);
            if (savedState) {
                return JSON.parse(savedState);
            }
            return null;
        }
    };
    var settings = $.extend(options, specials);
    var oTable = selector.DataTable(settings);
    customFilters.each(function(){
        var element = jQuery(this);
        var action = 'change';
        if (element.type == 'checkbox') {
            action = 'click';
        } else if (element.hasClass('datepicker') || element.hasClass('datetimepicker')) {
            action = 'dp.change';
        } else if (element.attr('type') == 'text') {
            element.keypress(function(e) {
                code = (e.keyCode ? e.keyCode : e.which);
                if (code == 13)
                    action = 'keypress';
            });
        }
        element.bind(action, function() {
            filterFormParams = {'name': 'filterForm', 'value': filterForm.serialize()};
            oTable.draw();
        });
    })
}

function registerGeneral() {
    $('div.dataTables_wrapper [data-toggle="tooltip"]').tooltip();

    /** Customize the datatable search. */
    $('div.dataTables_wrapper div.dataTables_filter label').prepend('<span class="glyphicon glyphicon-search"></span> ');
    $('div.dataTables_wrapper label').addClass('form-filter').css('margin-bottom', '10px').css('padding', '8px');

    $('div.dataTables_wrapper table').each(function() {
        var table = $(this).DataTable();

        var searchWait = 0;
        var searchWaitInterval;
        $('.dataTables_filter input')
            .unbind()
            .bind('input', function(e) {
                var item = $(this);
                searchWait = 0;
                if (! searchWaitInterval) searchWaitInterval = setInterval(function() {
                    if(searchWait >= 3){
                        clearInterval(searchWaitInterval);
                        searchWaitInterval = '';
                        var searchTerm = $(item).val();
                        table.search(searchTerm).draw();
                        searchWait = 0;
                    }
                    searchWait++;
            }, 500);
        });
    });
}

function registerAttended() {
    $('.attended').on('click', function(e) {
        var button = $(this);
        var url = $(this).data('id');
        $.get(url, function(data){
            if(data){
                if(data.button_class) {
                    var i = button.children('span');
                    i.attr('class', 'glyphicon ' + data.button_class);
                    var tr = button.parents('tr');
                    tr.removeClass('alert');
                    tr.addClass(data.row_class);
                } else {
                    var div = $('#ajaxMessage');
                    div.empty();
                    div.html(data.zertdbError);
                }
            }
        });
    });
}

function registerAlumniconfirm() {
    $('.alumniconfirm').on('click', function(e) {
        var button = $(this);
        var url = $(this).data('id');
        $.get(url, function(data){
            if(data){
                var div = $('#ajaxMessage');
                div.empty();
                div.html(data.zertdbError);
            }
        });
    });
}

function registerConfirmParticipation() {

    $(document).on('click', '.confirm-mail', function(e){
        var button = $(this);
        var url = $(this).data('id');
        var modalHeader = $('#modalEdit .modal-header');
        var isStudent = $('.is-student');
        isStudent.addClass('hide');
        var isConsent = $('.data-isConsent');
        isConsent.addClass('hide');
        var eCB = $('.data-checkbox-excel-file');
        eCB.addClass('hide');
        var eFrom = $('.modal-mail-from');
        eFrom.addClass('hide');
        if ($(this).data('checkbox-excel-file') == '1')
            eCB.removeClass('hide');
        if ($(this).data('is-consent') == '1')
            isConsent.removeClass('hide');
        var title = $(this).data('modal-title');
        $('.alert', modalHeader).text('').hide();
        $.get(url, function(data){
            if(data.status === 'success') {
                var form = document.confirmMail;
                form.epid.value = data.payload.epid;
                form.params.value = data.payload.params;
                form.mailType.value = data.payload.mailType;
                form.from.value = data.payload.from;
                form.to.value = data.payload.to;
                form.bcc.value = data.payload.bcc;
                form.subject.value = data.payload.subject;
                form.message.value = data.payload.message;
                title = title + ' ' + '(TemplateId: ' + data.payload.template + ')';
                if (data.payload.alreadySent) {
                    $('.alert', modalHeader).text('').html(data.payload.alreadySent).show();
                }
                if (data.payload.from && data.payload.from.length)
                    eFrom.removeClass('hide');
                if (data.isStudent == true)
                    isStudent.removeClass('hide');
                $('#modalEdit').modal();
            } else if (data.redirect == 1){
                window.location.href = data.url;
            } else {
                var div = $('#ajaxMessage');
                div.empty();
                div.html(data.payload);
            }
            $('.title', modalHeader).text(title);
        });
    });

    $(document).on('click', '.modalDialog', function(e){
        var button = $(this);
        var url = $(this).data('id');
        var modalHeader = $('#modalDialog .modal-header');
        $('.title', modalHeader).text($(this).data('modal-title'));
        $('.alert', modalHeader).text('').hide();
        $.get(url, function(data){
            $('.alert', modalHeader).text(data.title);
            if(data.status === 'success'){
                if (data.title) {
                    $('.title', modalHeader).text('').html(data.title).show();
                }
                if (data.alert) {
                    $('.alert', modalHeader).text('').html(data.alert).show();
                }
                $('#modalDialog .modal-body').text('').html(data.content).show();
                $('#modalDialog').modal();
            } else {
                var div = $('#ajaxMessage');
                div.empty();
                div.html(data.alert);
            }
        });
    });
}

function registerAddLearningObject() {
    $('.btn-add-learning-object').on('click', function(e) {
        var url = $(this).data('id');
        var row = $(this).parents('#form-question .row');
        $.get(url, function(data){
            if(data){
                row.prev().after(data);
            }
        });
    });
}

function registerAddExamProduct() {
    $('.btn-add-examproduct').on('click', function(e) {
        var count = $('.examProduct').length;
        count++;
        var url = $(this).data('id') + count;
        var row = $(this).parents('#form-exam .row');
        $.get(url, function(data){
            if(data){
                row.prev().append(data);
            }
        });
    });
}

function registerAddTrainingProviderPrices() {
    $('.btn-add-tp-product-prices').on('click', function(e) {
        var url = $(this).data('id') + '/product/' + $('#product').val();
        var form = $('#prices-trainingprovider');
        $.get(url, function(data){
            if(data){
                if(data.status == 200) {
                    form.append(data.html);
                } else {
                    $('#info').html(data.html);
                }
            }
        });
    });
}

